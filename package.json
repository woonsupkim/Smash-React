{
  "name": "smash-ui",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@sentry/react": "^10.66.0",
    "@supabase/supabase-js": "^2.78.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^13.5.0",
    "@vercel/analytics": "^2.0.1",
    "bootstrap": "^5.3.7",
    "framer-motion": "^12.23.0",
    "gh-pages": "^6.3.0",
    "lucide-react": "^1.23.0",
    "papaparse": "^5.5.3",
    "react": "^19.1.0",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^19.1.0",
    "react-router-dom": "^6.30.1",
    "react-select": "^5.10.1",
    "recharts": "^3.0.2",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint --max-warnings=0 --ext .js src",
    "e2e": "playwright test",
    "build-roster": "node data-pipeline/buildRoster.js",
    "fetch-images": "node data-pipeline/fetchImages.js",
    "fetch-stats": "node data-pipeline/fetch.js",
    "fetch-surfaces": "node data-pipeline/fetchSurfaces.js",
    "compute-stats": "node data-pipeline/computeStats.js",
    "build-stats-csv": "node data-pipeline/buildTournamentCsv.js",
    "build-upset-csv": "node data-pipeline/computeStats.js 7 \"\" upset && node data-pipeline/buildTournamentCsv.js upset",
    "fetch-profiles": "node data-pipeline/fetchProfiles.js",
    "compute-matchup-facts": "node data-pipeline/computeMatchupFacts.js",
    "backtest": "node data-pipeline/backtest.js",
    "refresh-stats": "npm run fetch-stats && npm run fetch-surfaces && npm run fetch-profiles && npm run compute-stats && npm run compute-matchup-facts && npm run build-stats-csv",
    "build-roster-women": "node data-pipeline/buildRoster.js 50 wta",
    "fetch-images-women": "node data-pipeline/fetchImages.js wta",
    "fetch-stats-women": "node data-pipeline/fetch.js wta",
    "fetch-surfaces-women": "node data-pipeline/fetchSurfaces.js wta",
    "compute-stats-women": "node data-pipeline/computeStats.js \"\" \"\" \"\" wta",
    "build-stats-csv-women": "node data-pipeline/buildTournamentCsv.js \"\" wta",
    "build-upset-csv-women": "node data-pipeline/computeStats.js 7 \"\" upset wta && node data-pipeline/buildTournamentCsv.js upset wta",
    "fetch-profiles-women": "node data-pipeline/fetchProfiles.js wta",
    "compute-matchup-facts-women": "node data-pipeline/computeMatchupFacts.js wta",
    "backtest-women": "node data-pipeline/backtest.js \"\" \"\" wta",
    "refresh-stats-women": "npm run fetch-stats-women && npm run fetch-surfaces-women && npm run fetch-profiles-women && npm run compute-stats-women && npm run compute-matchup-facts-women && npm run build-stats-csv-women",
    "build-track-record": "node data-pipeline/buildTrackRecord.js",
    "build-tuner-history": "node data-pipeline/buildTunerHistory.js",
    "compute-elo": "node data-pipeline/computeElo.js",
    "build-predictions": "node data-pipeline/buildPredictions.js",
    "check-guardrails": "node data-pipeline/checkGuardrails.js",
    "build-title-odds": "node data-pipeline/buildTitleOdds.js",
    "build-daily-scorecard": "node data-pipeline/buildDailyScorecard.js",
    "build-share-assets": "node data-pipeline/buildShareAssets.js",
    "build-motion-assets": "node data-pipeline/buildMotionAssets.js",
    "build-sitemap": "node data-pipeline/buildSitemap.js",
    "build-digest": "node data-pipeline/buildDigest.js",
    "build-season-rewind": "node data-pipeline/buildSeasonRewind.js",
    "send-push": "node data-pipeline/sendPush.js",
    "post-social": "node data-pipeline/postSocial.js"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "overrides": [
      {
        "files": [
          "**/*.test.js"
        ],
        "rules": {
          "jest/no-conditional-expect": "off"
        }
      }
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.1.11",
    "@vitejs/plugin-react": "^4.7.0",
    "dotenv": "^17.4.2",
    "eslint": "^8.57.1",
    "eslint-config-react-app": "^7.0.1",
    "typescript": "^4.9.5",
    "vite": "^6.4.3",
    "vitest": "^3.2.7"
  }
}
