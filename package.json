    "build-tuner-history": "node data-pipeline/buildTunerHistory.js",
    "compute-elo": "node data-pipeline/computeElo.js",
    "build-predictions": "node data-pipeline/buildPredictions.js",
    "check-guardrails": "node data-pipeline/checkGuardrails.js",
    "build-title-odds": "node data-pipeline/buildTitleOdds.js",
    "build-daily-scorecard": "node data-pipeline/buildDailyScorecard.js",
