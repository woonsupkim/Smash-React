RAPIDAPI_KEY=your_rapidapi_key_here

# Optional: hosted error tracking (Sentry). Leave blank to disable.
# When set, src/utils/monitoring.js is ready to forward uncaught errors.
REACT_APP_SENTRY_DSN=

# Optional: Supabase (accounts + cloud pools). Leave blank for
# localStorage-only mode. See supabase/SETUP.md for the 3-minute setup.
REACT_APP_SUPABASE_URL=
REACT_APP_SUPABASE_ANON_KEY=
